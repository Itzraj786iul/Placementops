# PlacementOS — root environment reference
# Copy app-specific files instead of using this directly:
#   cp apps/api/.env.example apps/api/.env
#   cp apps/web/.env.example apps/web/.env.local

# Frontend (apps/web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://localhost:8000
NEXT_PUBLIC_ENABLE_DEV_LOGIN=false

# Backend (apps/api/.env)
DATABASE_URL=postgresql://placementos:placementos@localhost:5432/placementos
ENVIRONMENT=local
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-secret
COOKIE_SECURE=false
ENABLE_DEV_LOGIN=false
ENABLE_API_DOCS=true
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Cloudinary (file storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=PlacementOS <onboarding@resend.dev>
EMAIL_PROVIDER=resend
