PROJECT_NAME=PlacementOS API
VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# local | development | staging | production
ENVIRONMENT=local

DATABASE_URL=postgresql://placementos:placementos@localhost:5432/placementos

CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

ALLOWED_EMAIL_DOMAIN=nitrr.ac.in

JWT_SECRET_KEY=change-me-in-production-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

COOKIE_SECURE=false

# Dev-only email/password login. Keep false unless you need local demos.
# Must remain false when ENVIRONMENT=production (API refuses to start otherwise).
ENABLE_DEV_LOGIN=false

# OpenAPI UI (/docs, /redoc). Omit to auto-disable in production.
# ENABLE_API_DOCS=true

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (Resend) — required for outbound notification emails
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=PlacementOS <onboarding@resend.dev>
EMAIL_PROVIDER=resend

# Deployed (staging/production) requirements enforced at API startup:
# - COOKIE_SECURE=true
# - ENABLE_DEV_LOGIN=false
# - JWT_SECRET_KEY >= 32 chars (not the default)
# - DATABASE_URL not localhost
# - FRONTEND_URL https://... and included in CORS_ORIGINS
# - Google OAuth client + public GOOGLE_REDIRECT_URI
